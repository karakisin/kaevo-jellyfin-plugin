# Kaevo Home Server provider orchestrator configuration.
# Copy this file to the TrueNAS deployment secret/environment editor and fill
# values there. Do not commit real values.

KAEVO_HOME_SERVER_DATA_DIR=/data
KAEVO_HOME_SERVER_SECRET_KEY=replace-with-long-random-secret
KAEVO_HOME_SERVER_IOS_TOKEN=replace-with-long-random-token

# Cloud is control-plane only. Provider credentials remain local and are never
# returned to or stored by Kaevo Cloud.
KAEVO_CLOUD_CONNECTOR_ENABLED=false
KAEVO_CLOUD_BASE_URL=https://your-kaevo-cloud.example
KAEVO_CLOUD_CONNECTOR_TOKEN=replace-with-token-returned-by-one-time-pairing
KAEVO_PLAYBACK_CONNECTOR_GRANT_KEY=replace-with-grant-key-returned-by-one-time-pairing
KAEVO_CLOUD_CONNECTOR_ID=replace-with-connector-id
KAEVO_CLOUD_PROFILE_ID=replace-with-kaevo-profile-id
KAEVO_PLAYBACK_RELAY_WEBSOCKET_URL=wss://your-kaevo-relay.example

# Jellyfin performs direct play, remux, and live transcoding on this server.
KAEVO_JELLYFIN_USER_ID=replace-with-local-jellyfin-user-id

# No real-media optimizer execution is enabled by configuration alone. A valid
# one-file plan, short-lived approval token, and exact confirmation are required.
KAEVO_OPTIMIZER_ALLOWED_MOVIES_ROOT=/media/Movies
KAEVO_OPTIMIZER_ALLOWED_TV_ROOT=/media/TV
KAEVO_OPTIMIZER_REAL_REMUX_ENABLED=false

# Container bind settings used by the sidecar deployment example.
KAEVO_HOME_SERVER_HOST=0.0.0.0
KAEVO_HOME_SERVER_PORT=8100
