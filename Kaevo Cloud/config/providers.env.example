# Kaevo Live Provider Config Example
# Copy this to config/providers.env.local and fill it in locally.
# Do not commit providers.env.local.

# Jellyfin
KAEVO_JELLYFIN_BASE_URL="http://YOUR-JELLYFIN-HOST:PORT"
KAEVO_JELLYFIN_USER_ID="YOUR_JELLYFIN_USER_ID"
KAEVO_JELLYFIN_TOKEN="YOUR_JELLYFIN_ACCESS_TOKEN"

# Seerr
KAEVO_SEERR_BASE_URL="http://YOUR-SEERR-HOST:PORT"
KAEVO_SEERR_API_KEY="YOUR_SEERR_API_KEY"

# Sonarr
KAEVO_SONARR_BASE_URL="http://YOUR-SONARR-HOST:PORT"
KAEVO_SONARR_API_KEY="YOUR_SONARR_API_KEY"

# Radarr
KAEVO_RADARR_BASE_URL="http://YOUR-RADARR-HOST:PORT"
KAEVO_RADARR_API_KEY="YOUR_RADARR_API_KEY"

# Downloaders - optional read-only status
# SABnzbd example: http://YOUR-TRUENAS-IP:30055
KAEVO_SABNZBD_BASE_URL=""
KAEVO_SABNZBD_API_KEY=""

# qBittorrent example: http://YOUR-TRUENAS-IP:30090
KAEVO_QBITTORRENT_BASE_URL=""
KAEVO_QBITTORRENT_USERNAME=""
KAEVO_QBITTORRENT_PASSWORD=""
